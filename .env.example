# UI 测试自动化平台 — 环境变量配置示例
# 复制为 .env 并根据环境修改

# 数据库
DATABASE_URL=sqlite:///./uitest.db

# 服务绑定
APP_HOST=0.0.0.0
APP_PORT=8002

# 认证
SESSION_EXPIRE_MINUTES=30
MAX_LOGIN_ATTEMPTS=5
LOCK_DURATION_MINUTES=15
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=Admin@2024

# Cookie 安全：生产环境 HTTPS 部署时必须设为 true，开启 Secure 标志
COOKIE_SECURE=false

# CORS
CORS_ALLOW_ORIGINS=http://localhost:5173,http://localhost:8002,http://192.168.100.173:8002
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,PATCH,OPTIONS
CORS_ALLOW_HEADERS=Content-Type,Authorization,X-Requested-With,Accept
